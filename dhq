# DHQ Nginx Configuration - Complete with SSL

# Upstream servers
upstream dhq_backend { server 127.0.0.1:8000; keepalive 32; }
upstream dhq_socketio { server 127.0.0.1:8001; keepalive 32; }
upstream dhq_frontend { server 127.0.0.1:3001; keepalive 32; }

# Rate limiting
limit_req_zone $binary_remote_addr zone=api:10m rate=10r/s;
limit_req_zone $binary_remote_addr zone=auth:10m rate=5r/s;

# HTTP to HTTPS redirect
server {
    listen 80;
    server_name haku.io.vn;
    return 301 https://$server_name$request_uri;
}

# HTTPS configuration
server {
    listen 443 ssl http2;
    server_name haku.io.vn;
    
    # SSL certificates
    ssl_certificate /etc/letsencrypt/live/haku.io.vn/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/haku.io.vn/privkey.pem;
    include /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem;
    
    # Security headers
    add_header X-Frame-Options "SAMEORIGIN" always;
    add_header X-XSS-Protection "1; mode=block" always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy "no-referrer-when-downgrade" always;
    add_header Content-Security-Policy "default-src 'self' http: https: data: blob: 'unsafe-inline' 'unsafe-eval'" always;
    
    # Gzip compression
    gzip on;
    gzip_vary on;
    gzip_min_length 1024;
    gzip_proxied expired no-cache no-store private auth;
    gzip_types text/plain text/css text/xml text/javascript application/javascript application/xml+rss application/json;
    
    # Client max body size
    client_max_body_size 2G;
    
    # Proxy settings
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
    proxy_set_header X-Forwarded-Proto $scheme;
    
    # Vite development server dependencies - MUST COME FIRST
    location /node_modules/ {
        proxy_pass http://dhq_frontend;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_cache_bypass $http_upgrade;
        proxy_read_timeout 86400;
    }
    
    # Vite HMR and development server - MUST COME FIRST
    location /@vite/ {
        proxy_pass http://dhq_frontend;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_cache_bypass $http_upgrade;
        proxy_read_timeout 86400;
    }
    
    # Backend API routes
    location /api/ {
        limit_req zone=api burst=20 nodelay;
        proxy_pass http://dhq_backend;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_cache_bypass $http_upgrade;
        proxy_connect_timeout 60s;
        proxy_send_timeout 60s;
        proxy_read_timeout 60s;
    }
    
    # Favicon - serve directly from frontend public
    location = /favicon.ico {
        root /home/haku/projects/DHQ_Root/frontend/public;
        expires 1y;
        add_header Cache-Control "public, immutable";
        access_log off;
    }
    
    # Shadow Garden login page - serve HTML for GET, proxy POST to backend
    location /shadow-garden/login {
        # Check if it's a POST request
        if ($request_method = POST) {
            proxy_pass http://dhq_backend;
            break;
        }
        
        # For GET requests, serve the HTML file
        root /home/haku/projects/DHQ_Root/frontend/public;
        try_files /shadow-garden/login.html =404;
    }
    
    # Socket.IO WebSocket connections
    location /socket.io/ {
        proxy_pass http://dhq_socketio;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_cache_bypass $http_upgrade;
        proxy_buffering off;
        proxy_read_timeout 86400;
    }
    
    # Frontend routes (Vue.js SPA) - catch-all after specific routes
    location / {
        proxy_pass http://dhq_frontend;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_cache_bypass $http_upgrade;
        proxy_read_timeout 86400;
    }
    
    # Fallback for frontend
    location @frontend {
        proxy_pass http://dhq_frontend;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_cache_bypass $http_upgrade;
        proxy_read_timeout 86400;
    }
    
    # More specific security rules (don't block node_modules)
    location ~ ^/\. { deny all; }
    location ~ \.(env|log|conf)$ { deny all; }
}
